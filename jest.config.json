{
  "moduleFileExtensions":[
    "js",
    "json",
    "ts"
  ],
  "rootDir":"./src",
  "testRegex":".spec.ts$",
  "transform":{
    "^.+\\.(t|j)s$":"ts-jest"
  },
  "coverageDirectory":"coverage",
  "testEnvironment":"node",
  "preset":"ts-jest",
  "moduleDirectories": ["node_modules", "src"],
  "coverageThreshold":{
    "global":{
      "branches":50,
      "functions":50,
      "lines":80,
      "statements":80
    }
  },
  "collectCoverageFrom":[
    "src/**/*.ts",
    "!src/**/*.{module,entity,dto}.ts",
    "!src/{main,config}.ts",
    "!src/database/**/*.ts",
    "!src/common/constants/*.ts"
  ]
}